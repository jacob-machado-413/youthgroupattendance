@page "/students"
@inject ApiService Api
@inject NavigationManager Nav

<h2>Students</h2>

<div>
    <input @bind="_search" @bind:event="oninput" placeholder="Search by name..." />
    <button @onclick="@Search">Search</button>
    <button @onclick="@LoadAll">Show All</button>
</div>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Grade</th>
                <th>Gender</th>
                <th>School</th>
                <th>Attendances</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in _students)
            {
                <tr @onclick="@(() => Nav.NavigateTo($"/students/{s.Id}"))" style="cursor:pointer;">
                    <td>@s.FullName</td>
                    <td>@GradeHelper.GraduationYearToGrade(s.GraduationYear)</td>
                    <td>@s.Gender</td>
                    <td>@s.School</td>
                    <td>@s.TotalAttendances</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(_error))
{
    <p class="error">@_error</p>
}

@code {
    private List<StudentResponse> _students = new();
    private string _search = string.Empty;
    private bool _loading;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        _loading = true;
        _error = null;
        try { _students = await Api.GetAllStudentsAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            await LoadAll();
            return;
        }
        _loading = true;
        _error = null;
        try { _students = await Api.SearchStudentsAsync(_search); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
