@page "/students/{Id:int}"
@inject ApiService Api
@inject NavigationManager Nav

@if (_student == null)
{
    <p>@(_loading ? "Loading..." : "Student not found.")</p>
}
else
{
    <h2>@_student.FullName</h2>
    <dl>
        <dt>Grade</dt>
        <dd>@GradeHelper.GraduationYearToGrade(_student.GraduationYear)</dd>
        <dt>Gender</dt>
        <dd>@(_student.Gender ?? "Not specified")</dd>
        <dt>School</dt>
        <dd>@(_student.School ?? "Not specified")</dd>
        <dt>Total Attendances</dt>
        <dd>@_student.Attendances.Count</dd>
    </dl>

    <h3>Attendance Trend — Last 12 Weeks</h3>
    <div class="chart">
        @foreach (var w in _weeklyData)
        {
            <div class="bar-column" title="@w.Label: @w.Count attendance(s)">
                <div class="bar" style="height: @(Math.Max(3, w.BarHeight))px; background: @w.BarColor;"></div>
                <div class="bar-label">@w.ShortLabel</div>
            </div>
        }
    </div>
    <div class="chart-legend">
        <span class="legend-green"></span> Attended
        <span class="legend-gray" style="margin-left: 1rem;"></span> Did not attend
    </div>

    <h3>Attendance History</h3>
    <table>
        <thead>
            <tr><th>Date</th><th>Event Type</th><th>Notes</th></tr>
        </thead>
        <tbody>
            @foreach (var a in _student.Attendances)
            {
                <tr>
                    <td>@a.Date.ToShortDateString()</td>
                    <td>@FormatEventType(a.EventType)</td>
                    <td>@a.Notes</td>
                </tr>
            }
        </tbody>
    </table>
}

<style>
    .chart { display: flex; align-items: flex-end; gap: 4px; height: 100px; padding: 10px 0; border-bottom: 1px solid #ccc; margin-bottom: 0.3rem; overflow-x: auto; }
    .bar-column { display: flex; flex-direction: column; align-items: center; flex: 1; min-width: 32px; }
    .bar { width: 20px; border-radius: 3px 3px 0 0; transition: height 0.3s; min-height: 3px; }
    .bar-label { font-size: 0.65rem; color: #666; margin-top: 4px; white-space: nowrap; }
    .chart-legend { font-size: 0.8rem; color: #555; margin-bottom: 1rem; }
    .legend-green, .legend-gray { display: inline-block; width: 12px; height: 12px; border-radius: 2px; vertical-align: middle; margin-right: 4px; }
    .legend-green { background: #4caf50; }
    .legend-gray { background: #e0e0e0; }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private StudentDetailResponse? _student;
    private bool _loading = true;
    private List<WeeklyBar> _weeklyData = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _student = await Api.GetStudentAsync(Id);
            if (_student != null)
                _weeklyData = BuildWeeklyChart(_student.Attendances);
        }
        catch { }
        finally { _loading = false; }
    }

    private static List<WeeklyBar> BuildWeeklyChart(List<AttendanceRecord> attendances)
    {
        var today = DateTime.UtcNow.Date;
        var bars = new List<WeeklyBar>();

        var start = today.AddDays(-(12 * 7));
        var daysToMonday = ((int)start.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
        start = start.AddDays(-daysToMonday);

        for (int w = 0; w < 12; w++)
        {
            var weekStart = start.AddDays(w * 7);
            var weekEnd = weekStart.AddDays(6);
            var count = attendances.Count(a => a.Date >= weekStart && a.Date <= weekEnd);

            bars.Add(new WeeklyBar
            {
                Label = $"{weekStart:MMM d} - {weekEnd:MMM d}",
                ShortLabel = weekStart.ToString("M/d"),
                Count = count,
                BarHeight = count > 0 ? Math.Max(12, (int)((double)count / 3 * 80)) : 3,
                BarColor = count > 0 ? "#4caf50" : "#e0e0e0"
            });
        }

        return bars;
    }

    private static string FormatEventType(string type) => type switch
    {
        "RegularYouthGroup" => "Regular Youth Group",
        "SocialGameNight" => "Social / Game Night",
        "ServiceProject" => "Service Project",
        "RetreatCamp" => "Retreat / Camp",
        _ => type
    };

    private class WeeklyBar
    {
        public string Label { get; set; } = "";
        public string ShortLabel { get; set; } = "";
        public int Count { get; set; }
        public int BarHeight { get; set; }
        public string BarColor { get; set; } = "#e0e0e0";
    }
}
